{
  "name": "github-agent",
  "version": "1.0.0",
  "description": "GitHub Intelligent Programming Agent with OpenSpec",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "dev:ui": "cd web-ui && npm run dev",
    "build:ui": "cd web-ui && npm run build",
    "install:all": "npm install && cd web-ui && npm install"
  },
  "dependencies": {
    "@fission-ai/openspec": "^1.2.0",
    "@octokit/rest": "^21.0.0",
    "express": "^4.18.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
